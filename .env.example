# =============================================================================
# DeepAgents Orchestrator Exemplar - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Do NOT commit your .env file to version control.
# =============================================================================

# --- LangSmith Observability ---
# API key for LangSmith tracing and monitoring
LANGSMITH_API_KEY=your-langsmith-api-key-here

# Enable or disable LangSmith tracing (true/false)
LANGSMITH_TRACING=true

# LangSmith project name for organizing traces
LANGSMITH_PROJECT=deepagents-orchestrator-exemplar

# --- LLM Provider API Keys ---
# Anthropic API key (required for Claude-based agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google API key (optional - for Gemini-based agents)
# GOOGLE_API_KEY=your-google-api-key-here

# --- Local Model Configuration ---
# Local model endpoint (optional - for locally hosted models)
# LOCAL_MODEL_ENDPOINT=http://localhost:8000/v1
